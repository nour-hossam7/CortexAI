# =========================
# Python / environment / cache
# =========================
venv/
.venv/
__pycache__/
.ipynb_checkpoints/
.DS_Store

# =========================
# Model checkpoints / weights
# =========================
*.pth
*.pt
*.h5
*.ckpt

# Exception: trained CV segmentation model — committed directly
# (confirmed under GitHub's 100MB limit; the .pt preprocessed
# volumes themselves stay ignored and are shared via Kaggle)
!models/segmentation/best_model.pth
!models/fusion/best_decision_model.pth

# Keep the shipped NLP embeddings and metadata so the Fusion and
# similar-patient features work on a fresh clone without missing files.
!datasets/processed/nlp/
!datasets/processed/nlp/**

# =========================
# Medical imaging files
# =========================
*.nii
*.nii.gz

# =========================
# Ignore heavy raw dataset contents
# =========================
datasets/raw/brats2020/*
datasets/raw/textbrats/*

# Keep raw folder placeholders
!datasets/raw/brats2020/.gitkeep
!datasets/raw/textbrats/.gitkeep

# =========================
# Ignore processed outputs
# =========================
datasets/processed/cv/*
datasets/processed/nlp/*
datasets/processed/fusion/*

# Keep processed folder placeholders
!datasets/processed/cv/.gitkeep
!datasets/processed/nlp/.gitkeep
!datasets/processed/fusion/.gitkeep

# Keep small metadata files needed by the CV pipeline code
# (the actual .pt volumes stay ignored — shared via Kaggle instead)
!datasets/processed/cv/dataset_split.json
!datasets/processed/cv/index.json

# =========================
# Sample data
# =========================
datasets/sample_data/*
!datasets/sample_data/.gitkeep
